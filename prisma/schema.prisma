// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id         String    @id @default(uuid(7)) @db.Uuid
  userId     String
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  revisions   RecipeRevision[]
  chatThreads ChatThread[]

  @@index([userId, archivedAt, createdAt])
}

model RecipeRevision {
  id         String   @id @default(uuid(7)) @db.Uuid
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId   String   @db.Uuid
  revision   Int
  authoredBy Author
  createdAt  DateTime @default(now())

  name         String   @db.VarChar(100)
  servings     Int
  ingredients  String[]
  instructions String   @db.VarChar(10000)
  duration     Int? // duration in minutes
  difficulty   Int? // scale: 1 (easy) to 10 (hard)

  @@unique([recipeId, revision])
}

model UserProfileRevision {
  id         String   @id @default(uuid(7)) @db.Uuid
  userId     String
  revision   Int
  content    String   @db.VarChar(10000)
  authoredBy Author
  createdAt  DateTime @default(now())

  @@unique([userId, revision])
}

enum Author {
  USER
  ASSISTANT
}

model RateLimit {
  userId       String
  day          DateTime @db.Date
  messageCount Int      @default(0)

  @@id([userId, day])
}

model ChatThread {
  id        String        @id @default(uuid(7)) @db.Uuid
  userId    String
  recipeId  String?       @db.Uuid // null = main-assistant thread; set = recipe-anchored
  recipe    Recipe?       @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  title     String? // assistant-generated label; null falls back in the UI
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([userId, updatedAt])
  @@index([userId, recipeId, updatedAt])
}

model ChatMessage {
  id        String      @id @db.Uuid // AI SDK message id (uuidv7-minted client/server)
  thread    ChatThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId  String      @db.Uuid
  role      MessageRole
  parts     Json
  createdAt DateTime    @default(now())

  @@index([threadId, createdAt])
}

// Chat-transport role, distinct from Author (recipe/profile authorship).
// SYSTEM/TOOL can be added when something actually persists them.
enum MessageRole {
  USER
  ASSISTANT
}
